---
import theme from '../data/theme.json';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MobileStickyCta from '../components/MobileStickyCta.astro';
import { withBase } from '../utils/base';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Dr. Insa Baumfalk – Kieferorthopädie Berlin', description = 'Kieferorthopädische Praxis Dr. Insa Baumfalk auf der Halbinsel Stralau in Berlin.' } = Astro.props;

type PresetKey = keyof typeof theme.presets;
const preset = theme.presets[theme.activePreset as PresetKey];
---
<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <title>{title}</title>
    <script is:inline src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
    <style define:vars={{
      primary: preset.primary,
      accent: preset.accent,
      background: preset.background,
      text: preset.text,
    }}>
      :root {
        --c-primary: var(--primary);
        --c-accent: var(--accent);
        --c-background: var(--background);
        --c-text: var(--text);
      }
    </style>
  </head>
  <body class="font-sans antialiased min-h-screen flex flex-col">
    <Header />
    <main class="flex-1 relative">
      <slot />
    </main>
    <Footer />
    <MobileStickyCta />
    <script is:inline>
      if (window.netlifyIdentity) {
        window.netlifyIdentity.on('init', (user) => {
          if (!user) {
            window.netlifyIdentity.on('login', () => {
              document.location.href = '/admin/';
            });
          }
        });
      }
    </script>
  </body>
</html>
