---
import { withBase } from '../utils/base';

interface Props {
  variant?: 'magazine' | 'overlay';
  eyebrow?: string;
  title: string;
  subtitle?: string;
  image?: string;
  imageAlt?: string;
  primaryCta?: { href: string; label: string; external?: boolean };
  secondaryCta?: { href: string; label: string };
  sticky?: boolean;
  imageCredit?: string;
}
const {
  variant = 'overlay',
  eyebrow,
  title,
  subtitle,
  image,
  imageAlt = '',
  primaryCta,
  secondaryCta,
  sticky = false,
  imageCredit,
} = Astro.props;
const overlayClasses = sticky
  ? 'sticky top-0 w-full h-screen overflow-hidden z-0'
  : 'relative w-full h-[50vh] md:h-[60vh] min-h-[360px] max-h-[640px] overflow-hidden';
---
{variant === 'magazine' ? (
  <section class="mx-auto max-w-6xl px-4 md:px-6 pt-10 md:pt-16 pb-8 md:pb-12">
    {eyebrow && <p class="eyebrow mb-6">{eyebrow}</p>}
    <h1 class="headline-xl text-text mb-6 md:mb-8 max-w-4xl" set:html={title} />
    {subtitle && (
      <p class="text-lg md:text-2xl opacity-80 max-w-3xl leading-relaxed mb-8 md:mb-10">{subtitle}</p>
    )}
    {(primaryCta || secondaryCta) && (
      <div class="flex flex-wrap gap-3 mb-10 md:mb-14">
        {primaryCta && (
          <a
            href={primaryCta.href}
            target={primaryCta.external ? '_blank' : undefined}
            rel={primaryCta.external ? 'noopener noreferrer' : undefined}
            data-primary-cta
            class="inline-block bg-primary text-background px-6 py-3.5 rounded-md font-medium hover:opacity-90 transition-opacity"
          >{primaryCta.label}</a>
        )}
        {secondaryCta && (
          <a href={secondaryCta.href} class="inline-block border border-primary text-primary px-6 py-3.5 rounded-md font-medium hover:bg-primary hover:text-background transition-colors">{secondaryCta.label}</a>
        )}
      </div>
    )}
    {image && (
      <img
        src={withBase(image)}
        alt={imageAlt}
        class="w-full aspect-[21/9] md:aspect-[21/8] object-cover rounded-xl"
        loading="eager"
      />
    )}
  </section>
) : (
  <section class={overlayClasses}>
    {image && (
      <img src={withBase(image)} alt={imageAlt} class="absolute inset-0 w-full h-full object-cover" loading="eager" />
    )}
    <div class="absolute inset-0 bg-gradient-to-b from-black/10 via-black/25 to-black/55"></div>
    {imageCredit && (
      <p class="absolute bottom-3 right-4 text-sm md:text-base text-white/80 z-10 select-none drop-shadow">Foto: {imageCredit}</p>
    )}
    <div class="relative z-10 h-full flex items-end">
      <div class="mx-auto w-full max-w-6xl px-4 md:px-6 pb-10 md:pb-16">
        {eyebrow && <p class="eyebrow mb-4" style="color: #E8DCC4;">{eyebrow}</p>}
        <h1 class="headline-xl headline-on-dark text-white max-w-4xl" set:html={title} />
        {subtitle && <p class="text-lg md:text-xl text-white/90 max-w-2xl mt-4 md:mt-6">{subtitle}</p>}
        {(primaryCta || secondaryCta) && (
          <div class="flex flex-wrap gap-3 mt-6 md:mt-8">
            {primaryCta && (
              <a
                href={primaryCta.href}
                target={primaryCta.external ? '_blank' : undefined}
                rel={primaryCta.external ? 'noopener noreferrer' : undefined}
                data-primary-cta
                class="inline-block bg-primary text-background px-6 py-3.5 rounded-md font-medium hover:opacity-90 transition-opacity"
              >{primaryCta.label}</a>
            )}
            {secondaryCta && (
              <a href={secondaryCta.href} class="inline-block border border-white/80 text-white px-6 py-3.5 rounded-md font-medium hover:bg-white hover:text-text transition-colors">{secondaryCta.label}</a>
            )}
          </div>
        )}
      </div>
    </div>
  </section>
)}

<style is:global>
  .headline-on-dark em {
    color: #E8DCC4;
  }
</style>
