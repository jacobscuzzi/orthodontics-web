---
import { getCollection } from 'astro:content';
import ReviewCard from './ReviewCard.astro';
import site from '../data/site.json';

const all = await getCollection('reviews');
const featured = all
  .filter((r) => r.data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);

const reviewsWithText = await Promise.all(
  featured.map(async (r) => ({
    data: r.data,
    body: r.body?.trim() ?? '',
  }))
);

const googleReviews = (site as any).googleReviews ?? { averageRating: 5.0, totalCount: 35, googleMapsUrl: '#' };
---
<div class="mx-auto max-w-6xl px-4 md:px-6 py-20 md:py-28">
  <div class="max-w-3xl mb-14 md:mb-20">
    <p class="eyebrow mb-5">Stimmen unserer Patienten</p>
    <h2 class="headline-lg text-text" set:html={`Was <em>Patienten</em> sagen.`} />
  </div>

  <div class="grid gap-6 md:grid-cols-3 mb-12 md:mb-16">
    {reviewsWithText.map(({ data, body }) => (
      <ReviewCard
        author={data.author}
        rating={data.rating}
        date={data.date}
        excerpt={body}
      />
    ))}
  </div>

  <div class="flex flex-col md:flex-row md:items-center gap-5 md:gap-8 pt-8 border-t border-primary/15">
    <div class="flex items-center gap-3">
      <div class="flex gap-0.5 text-2xl">
        {Array.from({ length: 5 }).map(() => <span class="text-accent">★</span>)}
      </div>
      <div>
        <p class="font-display text-2xl leading-none">{googleReviews.averageRating.toFixed(1)} / 5</p>
        <p class="text-sm opacity-70 mt-1">basierend auf {googleReviews.totalCount} Google-Bewertungen</p>
      </div>
    </div>
    <a
      href={googleReviews.googleMapsUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="md:ml-auto inline-flex items-center gap-2 text-primary font-medium hover:underline"
    >
      Alle Bewertungen auf Google lesen
      <span aria-hidden="true">→</span>
    </a>
  </div>
</div>
