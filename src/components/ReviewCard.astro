---
interface Props {
  author: string;
  rating: number;
  date?: string;
  excerpt: string;
}
const { author, rating, date, excerpt } = Astro.props;
const formattedDate = date
  ? new Date(date).toLocaleDateString('de-DE', { year: 'numeric', month: 'long' })
  : undefined;
---
<article class="bg-background rounded-xl p-7 md:p-8 flex flex-col h-full border border-primary/10">
  <div class="flex gap-1 mb-5 text-xl" aria-label={`${rating} von 5 Sternen`}>
    {Array.from({ length: 5 }).map((_, i) => (
      <span class={i < rating ? 'text-accent' : 'text-primary/20'}>★</span>
    ))}
  </div>
  <blockquote class="font-display italic text-lg md:text-xl leading-snug mb-6 flex-1">
    „{excerpt}"
  </blockquote>
  <footer class="text-sm opacity-70">
    <p class="font-medium text-text">{author}</p>
    {formattedDate && <p class="mt-0.5">{formattedDate}</p>}
  </footer>
</article>
