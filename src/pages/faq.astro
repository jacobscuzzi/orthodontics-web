---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry, getCollection, render } from 'astro:content';
import Hero from '../components/Hero.astro';

const intro = await getEntry('pages', 'faq');
if (!intro) throw new Error('pages/faq.md missing');
const { Content: IntroContent } = await render(intro);

const items = (await getCollection('faq')).sort((a, b) => a.data.order - b.data.order);
const rendered = await Promise.all(
  items.map(async (item) => {
    const { Content } = await render(item);
    return { data: item.data, Content };
  })
);
---
<BaseLayout title="Frage & Antwort – Dr. Insa Baumfalk">
  <Hero
    variant="overlay"
    eyebrow="Häufige Fragen"
    title={`Fragen & <em>Antworten</em>.`}
    image={intro.data.heroImage}
    imageAlt={intro.data.heroAlt}
  />

  <div class="mx-auto max-w-3xl px-4 md:px-6 py-16 md:py-24">
    <div class="prose prose-lg max-w-none mb-12 md:mb-16">
      <IntroContent />
    </div>

    <div class="space-y-4">
      {rendered.map(({ data, Content }) => (
        <details class="group border border-primary/15 rounded-xl px-6 py-5 md:px-7 md:py-6 bg-background open:bg-band transition-colors">
          <summary class="cursor-pointer font-display text-xl md:text-2xl flex items-start justify-between gap-4 list-none">
            <span class="flex-1">{data.question}</span>
            <span class="text-primary text-3xl leading-none transition-transform group-open:rotate-45 shrink-0" aria-hidden="true">+</span>
          </summary>
          <div class="prose max-w-none mt-5 opacity-90"><Content /></div>
        </details>
      ))}
    </div>
  </div>
</BaseLayout>
