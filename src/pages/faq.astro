---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry, getCollection, render } from 'astro:content';

const intro = await getEntry('pages', 'faq');
if (!intro) throw new Error('pages/faq.md missing');
const { Content: IntroContent } = await render(intro);

const items = (await getCollection('faq')).sort((a, b) => a.data.order - b.data.order);
const rendered = await Promise.all(
  items.map(async (item) => {
    const { Content } = await render(item);
    return { data: item.data, Content };
  })
);
---
<BaseLayout title="Frage & Antwort – Dr. Insa Baumfalk">
  <div class="mx-auto max-w-3xl px-4 md:px-6 py-12 md:py-16">
    <h1 class="font-display text-4xl md:text-5xl text-primary mb-6">{intro.data.title}</h1>
    <div class="prose prose-lg max-w-none mb-10">
      <IntroContent />
    </div>

    <div class="space-y-3">
      {rendered.map(({ data, Content }) => (
        <details class="group border border-primary/20 rounded-md p-5 bg-background open:bg-primary/5">
          <summary class="cursor-pointer font-medium text-lg flex items-start justify-between gap-4">
            <span>{data.question}</span>
            <span class="text-primary text-2xl leading-none transition-transform group-open:rotate-45 shrink-0">+</span>
          </summary>
          <div class="prose max-w-none mt-4"><Content /></div>
        </details>
      ))}
    </div>
  </div>
</BaseLayout>
