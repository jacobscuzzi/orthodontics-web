---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry, render } from 'astro:content';

const page = await getEntry('pages', 'datenschutz');
if (!page) throw new Error('pages/datenschutz.md missing');
const { Content } = await render(page);
---
<BaseLayout title="Datenschutz – Dr. Insa Baumfalk">
  <article class="mx-auto max-w-3xl px-4 md:px-6 py-12 md:py-16">
    <h1 class="font-display text-4xl md:text-5xl text-primary mb-8">{page.data.title}</h1>
    <div class="prose max-w-none prose-headings:font-display prose-headings:text-primary">
      <Content />
    </div>
  </article>
</BaseLayout>
