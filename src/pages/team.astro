---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry, getCollection, render } from 'astro:content';
import Hero from '../components/Hero.astro';
import SectionBand from '../components/SectionBand.astro';

const intro = await getEntry('pages', 'team');
if (!intro) throw new Error('pages/team.md missing');
const { Content: IntroContent } = await render(intro);

const members = (await getCollection('team')).sort((a, b) => a.data.order - b.data.order);
const rendered = await Promise.all(
  members.map(async (m) => {
    const { Content } = await render(m);
    return { data: m.data, Content };
  })
);
---
<BaseLayout title="Team – Dr. Insa Baumfalk">
  <Hero
    variant="overlay"
    eyebrow="Unser Team"
    title={`Kleines <em>Team</em>, ganze Aufmerksamkeit.`}
    image={intro.data.heroImage}
    imageAlt={intro.data.heroAlt}
  />

  <section class="mx-auto max-w-3xl px-4 md:px-6 py-20 md:py-24 text-center">
    <div class="prose prose-lg max-w-none mx-auto">
      <IntroContent />
    </div>
  </section>

  {rendered.map(({ data, Content }, i) => {
    const imageLeft = i % 2 === 0;
    const band = i % 2 === 1;
    return (
      <SectionBand tone={band ? 'band' : 'background'}>
        <div class="mx-auto max-w-6xl px-4 md:px-6 py-14 md:py-20">
          <div class="grid gap-8 md:gap-14 md:grid-cols-12 items-center">
            {data.photo && (
              <div class:list={['md:col-span-5', imageLeft ? 'md:order-1' : 'md:order-2']}>
                <img
                  src={data.photo}
                  alt={`Foto von ${data.name}`}
                  class="w-full aspect-[4/5] object-cover rounded-xl"
                  loading="lazy"
                />
              </div>
            )}
            <div class:list={['md:col-span-7', imageLeft ? 'md:order-2' : 'md:order-1']}>
              <p class="eyebrow mb-4">{`0${i + 1}`} — {data.role}</p>
              <h2 class="headline-lg mb-5">{data.name}</h2>
              <div class="prose prose-lg max-w-none text-base md:text-lg leading-relaxed opacity-90"><Content /></div>
            </div>
          </div>
        </div>
      </SectionBand>
    );
  })}
</BaseLayout>
