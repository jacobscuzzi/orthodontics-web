---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry, getCollection, render } from 'astro:content';

const intro = await getEntry('pages', 'team');
if (!intro) throw new Error('pages/team.md missing');
const { Content: IntroContent } = await render(intro);

const members = (await getCollection('team')).sort((a, b) => a.data.order - b.data.order);
const rendered = await Promise.all(
  members.map(async (m) => {
    const { Content } = await render(m);
    return { data: m.data, Content };
  })
);
---
<BaseLayout title="Team – Dr. Insa Baumfalk">
  <div class="mx-auto max-w-4xl px-4 md:px-6 py-12 md:py-16">
    <h1 class="font-display text-4xl md:text-5xl text-primary mb-8">{intro.data.title}</h1>
    <div class="prose prose-lg max-w-none mb-12">
      <IntroContent />
    </div>

    <ul class="grid gap-6 md:grid-cols-2 list-none p-0">
      {rendered.map(({ data, Content }) => (
        <li class="bg-primary/5 rounded-lg p-6">
          <h2 class="font-display text-2xl text-primary">{data.name}</h2>
          <p class="text-sm opacity-70 mb-3">{data.role}</p>
          <div class="prose prose-sm max-w-none"><Content /></div>
        </li>
      ))}
    </ul>
  </div>
</BaseLayout>
