---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry } from 'astro:content';
import site from '../data/site.json';
import ui from '../data/ui.json';
import { em } from '../lib/em';
import SectionBand from '../components/SectionBand.astro';
import ReviewsSection from '../components/ReviewsSection.astro';
import MapEmbed from '../components/MapEmbed.astro';
import { withBase } from '../utils/base';

const home = await getEntry('pages', 'home');
if (!home) throw new Error('pages/home.md missing');
const {
  heroTitle, heroImage, heroAlt, heroCredit,
  heroCtaPrimaryLabel, heroCtaSecondaryLabel,
  reviews, features, interludeTitle, findUs, faqTeaser,
} = home.data;
const address = `${site.practice.street} · ${site.practice.zip} ${site.practice.city}`;
---
<BaseLayout title={`${site.practice.name} – ${ui.seoTitleSuffix}`}>
  <section class="sticky top-0 w-full h-screen overflow-hidden z-0">
    <img src={withBase(heroImage ?? '')} alt={heroAlt} class="absolute inset-0 w-full h-full object-cover" loading="eager" />
    <div class="absolute inset-0 bg-gradient-to-b from-black/10 via-black/25 to-black/55"></div>
    {heroCredit && (
      <p class="absolute bottom-3 right-4 text-sm md:text-base text-white/80 z-10 select-none drop-shadow">{heroCredit}</p>
    )}
  </section>

  <div class="absolute top-0 inset-x-0 h-screen flex items-end pointer-events-none z-20">
    <div class="mx-auto w-full max-w-6xl px-4 md:px-6 pb-10 md:pb-16 pointer-events-auto">
      <h1 class="headline-xl headline-on-dark text-white max-w-4xl" set:html={em(heroTitle ?? site.practice.name)} />
      <div class="flex flex-wrap gap-3 mt-6 md:mt-8">
        <a
          href={site.practice.doctolibUrl}
          target="_blank"
          rel="noopener noreferrer"
          data-primary-cta
          class="inline-block bg-primary text-background px-6 py-3.5 rounded-md font-medium hover:opacity-90 transition-opacity"
        >{heroCtaPrimaryLabel ?? 'Termin buchen'}</a>
        <a
          href={withBase('/praxis')}
          class="inline-block border border-white/80 text-white px-6 py-3.5 rounded-md font-medium hover:bg-white hover:text-text transition-colors"
        >{heroCtaSecondaryLabel ?? 'Die Praxis kennenlernen'}</a>
      </div>
    </div>
  </div>

  <div class="relative z-10 bg-background">
  <SectionBand tone="band">
    <ReviewsSection eyebrow={reviews?.eyebrow} title={reviews?.title} />
  </SectionBand>

  {features && (
    <section class="mx-auto max-w-6xl px-4 md:px-6 py-20 md:py-28">
      <div class="max-w-3xl mb-14 md:mb-20">
        <p class="eyebrow mb-5">{features.eyebrow}</p>
        <h2 class="headline-lg" set:html={em(features.title)} />
      </div>
      <div class="grid gap-10 md:grid-cols-3">
        {features.items.map((item, i) => (
          <div>
            <p class="font-display italic text-accent text-xl mb-3">{String(i + 1).padStart(2, '0')}</p>
            <h3 class="headline-md mb-3">{item.title}</h3>
            <p class="text-base md:text-lg opacity-80 leading-relaxed">{item.text}</p>
          </div>
        ))}
      </div>
      <div class="mt-12 md:mt-16">
        <a
          href={withBase('/behandlung')}
          class="inline-block bg-primary text-background px-6 py-3.5 rounded-md font-medium hover:opacity-90 transition-opacity"
        >{features.ctaLabel ?? 'Unsere Behandlungen entdecken'}</a>
      </div>
    </section>
  )}
  </div>

  <div class="relative h-[60vh] md:h-[70vh] flex items-center justify-center">
    <div class="absolute inset-0 bg-gradient-to-b from-black/40 via-black/25 to-black/40 pointer-events-none"></div>
    {interludeTitle && (
      <p class="relative z-10 text-white headline-lg text-center px-6 max-w-3xl drop-shadow" set:html={em(interludeTitle)} />
    )}
  </div>

  <div class="relative z-10 bg-background">
  <SectionBand tone="band">
    <div class="mx-auto max-w-6xl px-4 md:px-6 py-20 md:py-28">
      <div class="grid gap-10 md:gap-14 md:grid-cols-2 items-center">
        <div>
          <h2 class="headline-lg mb-6" set:html={em(findUs?.title ?? 'So findest Du zu *uns*.')} />
          <p class="text-lg opacity-80 leading-relaxed mb-4">{address}</p>
          {findUs && <p class="text-base opacity-70 leading-relaxed mb-8">{findUs.text}</p>}
          <a href={withBase('/kontakt')} class="inline-block border border-primary text-primary px-6 py-3 rounded-md font-medium hover:bg-primary hover:text-background transition-colors">{findUs?.ctaLabel ?? 'Anfahrt & Kontakt'}</a>
        </div>
        <MapEmbed size="small" />
      </div>
    </div>
  </SectionBand>

  {faqTeaser && (
    <section class="mx-auto max-w-6xl px-4 md:px-6 py-20 md:py-28">
      <div class="max-w-3xl">
        <p class="eyebrow mb-5">{faqTeaser.eyebrow}</p>
        <h2 class="headline-lg mb-6" set:html={em(faqTeaser.title)} />
        <p class="text-lg md:text-xl opacity-80 leading-relaxed mb-8">{faqTeaser.text}</p>
        <a href={withBase('/faq')} class="inline-block border border-primary text-primary px-6 py-3 rounded-md font-medium hover:bg-primary hover:text-background transition-colors">
          {faqTeaser.ctaLabel ?? 'Zur Frage & Antwort-Seite'}
        </a>
      </div>
    </section>
  )}
  </div>
</BaseLayout>
