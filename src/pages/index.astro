---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry } from 'astro:content';
import site from '../data/site.json';
import Hero from '../components/Hero.astro';
import SectionBand from '../components/SectionBand.astro';
import ReviewsSection from '../components/ReviewsSection.astro';

const home = await getEntry('pages', 'home');
if (!home) throw new Error('pages/home.md missing');
---
<BaseLayout title={`${site.practice.name} – Kieferorthopädie Berlin Stralau`}>
  <Hero
    variant="magazine"
    title="Inselpraxis."
    subtitle="Die Kieferorthopädische Praxis auf Alt-Stralau."
    image={home.data.heroImage}
    imageAlt={home.data.heroAlt}
    primaryCta={{ href: site.practice.doctolibUrl, label: 'Termin buchen', external: true }}
  />

  <SectionBand tone="band">
    <ReviewsSection />
  </SectionBand>
</BaseLayout>
