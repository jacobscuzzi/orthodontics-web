---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry, render } from 'astro:content';

const page = await getEntry('pages', 'behandlung');
if (!page) throw new Error('pages/behandlung.md missing');
const { Content } = await render(page);
---
<BaseLayout title={`${page.data.title} – Dr. Insa Baumfalk`}>
  {page.data.heroImage && (
    <div class="mx-auto max-w-5xl px-4 md:px-6 pt-8 md:pt-10">
      <img
        src={page.data.heroImage}
        alt={page.data.heroAlt ?? ''}
        class="w-full h-64 md:h-80 object-cover rounded-lg"
        loading="eager"
      />
    </div>
  )}
  <article class="mx-auto max-w-3xl px-4 md:px-6 py-12 md:py-16">
    <h1 class="font-display text-4xl md:text-5xl text-primary mb-8">{page.data.title}</h1>
    <div class="prose prose-lg max-w-none prose-headings:font-display prose-headings:text-primary">
      <Content />
    </div>
  </article>
  {page.data.gallery && page.data.gallery.length > 0 && (
    <section class="mx-auto max-w-5xl px-4 md:px-6 pb-16">
      <div class="grid gap-4 grid-cols-2 md:grid-cols-3">
        {page.data.gallery.map((img) => (
          <img
            src={img.src}
            alt={img.alt ?? ''}
            class="w-full h-48 md:h-56 object-cover rounded-lg"
            loading="lazy"
          />
        ))}
      </div>
    </section>
  )}
</BaseLayout>
