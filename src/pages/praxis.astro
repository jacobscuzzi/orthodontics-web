---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry, render } from 'astro:content';

const page = await getEntry('pages', 'praxis');
if (!page) throw new Error('pages/praxis.md missing');
const { Content } = await render(page);
---
<BaseLayout title={`${page.data.title} – Dr. Insa Baumfalk`}>
  <article class="mx-auto max-w-3xl px-4 md:px-6 py-12 md:py-16">
    <h1 class="font-display text-4xl md:text-5xl text-primary mb-8">{page.data.title}</h1>
    <div class="prose prose-lg max-w-none">
      <Content />
    </div>
  </article>
</BaseLayout>
