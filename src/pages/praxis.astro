---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry, render } from 'astro:content';
import Hero from '../components/Hero.astro';
import SectionBand from '../components/SectionBand.astro';
import { withBase } from '../utils/base';

const page = await getEntry('pages', 'praxis');
if (!page) throw new Error('pages/praxis.md missing');
const { Content } = await render(page);
const gallery = page.data.gallery ?? [];
---
<BaseLayout title={`${page.data.title} – Dr. Insa Baumfalk`}>
  <Hero
    variant="overlay"
    eyebrow="Die Praxis"
    title={`Praxis mit <em>Ausblick</em>.`}
    image={page.data.heroImage}
    imageAlt={page.data.heroAlt}
  />

  <section class="mx-auto max-w-5xl px-4 md:px-6 py-20 md:py-28">
    <div class="prose prose-lg md:prose-xl max-w-none prose-headings:font-display prose-headings:text-primary prose-p:leading-relaxed">
      <Content />
    </div>
    <div class="mt-10 md:mt-14">
      <a
        href={withBase('/team')}
        class="inline-block bg-primary text-background px-6 py-3.5 rounded-md font-medium hover:opacity-90 transition-opacity"
      >Unser Team kennenlernen</a>
    </div>
  </section>

  {gallery.length > 0 && (
    <SectionBand tone="band">
      <div class="mx-auto max-w-6xl px-4 md:px-6 py-20 md:py-28">
        <div class="max-w-3xl mb-14 md:mb-20">
          <p class="eyebrow mb-5">Einblicke</p>
          <h2 class="headline-lg" set:html={`Aus unseren <em>Räumen</em>.`} />
        </div>
        <div class="grid gap-4 md:gap-6 grid-cols-6 auto-rows-[160px] md:auto-rows-[220px]">
          {gallery.map((img, i) => {
            const patterns = [
              'col-span-6 md:col-span-4 row-span-2',
              'col-span-3 md:col-span-2 row-span-1',
              'col-span-3 md:col-span-2 row-span-1',
              'col-span-6 md:col-span-3 row-span-2',
              'col-span-6 md:col-span-3 row-span-2',
            ];
            return (
              <div class:list={['relative overflow-hidden rounded-xl', patterns[i % patterns.length]]}>
                <img src={withBase(img.src)} alt={img.alt ?? ''} class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
              </div>
            );
          })}
        </div>
      </div>
    </SectionBand>
  )}
</BaseLayout>
