---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry, render } from 'astro:content';
import site from '../data/site.json';
import Hero from '../components/Hero.astro';
import SectionBand from '../components/SectionBand.astro';
import MapEmbed from '../components/MapEmbed.astro';

const page = await getEntry('pages', 'kontakt');
if (!page) throw new Error('pages/kontakt.md missing');
const { Content } = await render(page);
const phoneHref = `tel:${site.practice.phone.replace(/\s/g, '').replace(/-/g, '')}`;
---
<BaseLayout title="Kontakt – Dr. Insa Baumfalk">
  <Hero
    variant="overlay"
    eyebrow="Kontakt"
    title={`So <em>findest</em> Du uns.`}
    image={page.data.heroImage}
    imageAlt={page.data.heroAlt}
  />

  <section class="mx-auto max-w-6xl px-4 md:px-6 py-16 md:py-24">
    <div class="grid gap-10 md:gap-14 md:grid-cols-12">
      <div class="md:col-span-5 space-y-10">
        <div>
          <p class="eyebrow mb-4">Adresse</p>
          <p class="text-xl font-display mb-1">{site.practice.name}</p>
          <p class="opacity-80">{site.practice.street}</p>
          <p class="opacity-80">{site.practice.zip} {site.practice.city}</p>
        </div>
        <div>
          <p class="eyebrow mb-4">Direkt Kontakt</p>
          <p class="mb-1">
            <a href={phoneHref} class="text-lg hover:text-primary">{site.practice.phone}</a>
          </p>
          <p>
            <a href={`mailto:${site.practice.email}`} class="hover:text-primary break-all text-base opacity-80">
              {site.practice.email}
            </a>
          </p>
        </div>
        <div>
          <p class="eyebrow mb-4">Öffnungszeiten</p>
          <ul class="space-y-1.5">
            {site.hours.map(h => (
              <li class="flex justify-between gap-3 text-base">
                <span class="font-medium">{h.day}</span>
                <span class="opacity-80 text-right">{h.time || '–'}</span>
              </li>
            ))}
          </ul>
          {site.hoursNote && <p class="mt-4 text-sm opacity-65">{site.hoursNote}</p>}
        </div>
        <a
          href={site.practice.doctolibUrl}
          target="_blank"
          rel="noopener noreferrer"
          data-primary-cta
          class="inline-block bg-primary text-background px-6 py-3 rounded-md font-medium hover:opacity-90 transition-opacity"
        >
          Online-Termin buchen
        </a>
      </div>

      <div class="md:col-span-7">
        <MapEmbed size="large" />
      </div>
    </div>
  </section>

  <SectionBand tone="band">
    <section class="mx-auto max-w-5xl px-4 md:px-6 py-20 md:py-28">
      <img
        src="/uploads/bild-kontakt.jpg"
        alt="Die Praxis auf der Halbinsel Stralau"
        class="w-full h-auto mb-12 md:mb-16"
        loading="lazy"
      />
      <article class="prose prose-lg md:prose-xl max-w-none prose-headings:font-display prose-headings:text-primary">
        <Content />
      </article>
    </section>
  </SectionBand>
</BaseLayout>
