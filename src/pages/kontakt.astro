---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry, render } from 'astro:content';
import site from '../data/site.json';

const page = await getEntry('pages', 'kontakt');
if (!page) throw new Error('pages/kontakt.md missing');
const { Content } = await render(page);
const phoneHref = `tel:${site.practice.phone.replace(/\s/g, '').replace(/-/g, '')}`;
---
<BaseLayout title="Kontakt – Dr. Insa Baumfalk">
  {page.data.heroImage && (
    <div class="mx-auto max-w-5xl px-4 md:px-6 pt-8 md:pt-10">
      <img
        src={page.data.heroImage}
        alt={page.data.heroAlt ?? ''}
        class="w-full h-64 md:h-80 object-cover rounded-lg"
        loading="eager"
      />
    </div>
  )}
  <div class="mx-auto max-w-4xl px-4 md:px-6 py-12 md:py-16">
    <h1 class="font-display text-4xl md:text-5xl text-primary mb-8">{page.data.title}</h1>

    <div class="grid gap-8 md:grid-cols-2 mb-12">
      <div class="bg-primary/5 rounded-lg p-6">
        <h2 class="font-display text-xl text-primary mb-3">Adresse</h2>
        <p>{site.practice.name}</p>
        <p>{site.practice.street}</p>
        <p>{site.practice.zip} {site.practice.city}</p>
        <p class="mt-4">
          <a href={phoneHref} class="hover:text-primary">Tel: {site.practice.phone}</a>
        </p>
        <p>
          <a href={`mailto:${site.practice.email}`} class="hover:text-primary break-all">
            {site.practice.email}
          </a>
        </p>
        <a
          href={site.practice.doctolibUrl}
          target="_blank"
          rel="noopener noreferrer"
          data-primary-cta
          class="mt-6 inline-block bg-primary text-background px-5 py-2.5 rounded-md font-medium hover:opacity-90 transition-opacity"
        >
          Online-Termin buchen
        </a>
      </div>

      <div class="bg-primary/5 rounded-lg p-6">
        <h2 class="font-display text-xl text-primary mb-3">Öffnungszeiten</h2>
        <ul class="space-y-1">
          {site.hours.map(h => (
            <li class="flex justify-between gap-3">
              <span class="font-medium">{h.day}</span>
              <span class="opacity-80 text-right">{h.time || '—'}</span>
            </li>
          ))}
        </ul>
        {site.hoursNote && <p class="mt-4 text-sm opacity-70">{site.hoursNote}</p>}
      </div>
    </div>

    <article class="prose prose-lg max-w-none prose-headings:font-display prose-headings:text-primary">
      <Content />
    </article>
  </div>
</BaseLayout>
